<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.pastemax.daemon</string>

    <key>ProgramArguments</key>
    <array>
        <string>/usr/local/bin/pastemax</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <!-- Lightweight: only run when user is logged in -->
    <key>LimitLoadToSessionType</key>
    <string>Aqua</string>

    <key>StandardOutPath</key>
    <string>/tmp/pastemax/pastemax.log</string>

    <key>StandardErrorPath</key>
    <string>/tmp/pastemax/pastemax.error.log</string>
</dict>
</plist>
